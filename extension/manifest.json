{
  "manifest_version": 3,
  "name": "TL;DRead",
  "version": "1.0",
  "description": "Summarize any webpage instantly. Local via Qwen or cloud via Gemini.",
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "permissions": ["activeTab", "scripting", "storage", "sidePanel"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "16": "favicon.png",
    "48": "favicon.png",
    "128": "favicon.png"
  },
  "action": {
    "default_icon": "favicon.png"
  }
}
